<!-- Example Scoreboard Configuration for Rugby League 

     * Home & Away Scores with 4,2,1 shortcuts in dashboard
     * Home & Away Names
     * Match Clock
     * Period
-->
<ScoreboardConfig>
    <persistence_file>afl.json</persistence_file>
    <widget>
        <id>home_goals</id>
        <type>Counter</type>
        <initial_value>0</initial_value>
    </widget>

    <widget>
        <id>home_behinds</id>
        <type>Counter</type>
        <initial_value>0</initial_value>
    </widget>

    <widget>
        <id>away_goals</id>
        <type>Counter</type>
        <initial_value>0</initial_value>
    </widget>

    <widget>
        <id>away_behinds</id>
        <type>Counter</type>
        <initial_value>0</initial_value>
    </widget>

    <widget>
        <id>match_clock</id>
        <type>Timer</type>
        <initial_seconds>0</initial_seconds>
        <is_down>false</is_down>
        <min_value>0</min_value>
        <max_value>1200</max_value>
    </widget>

    <widget>
        <id>shot_clock</id>
        <type>Timer</type>
        <initial_seconds>30</initial_seconds>
        <is_down>true</is_down>
        <min_value>0</min_value>
        <max_value>30</max_value>
	<reset_on_start>true</reset_on_start>
    </widget>


    <widget>
        <id>period</id>
        <type>List</type>
        <initial_index>0</initial_index>
	<options>
	    <option>PRE GAME</option>
            <option>1ST QTR</option>
	    <option>1/4</option>
            <option>2ND QTR</option>
            <option>HALFTIME</option>
            <option>3RD QTR</option>
	    <option>3/4</option>
            <option>4TH QTR</option>
            <option>FULLTIME</option>
        </options>
    </widget>

    <widget>
        <id>home_team</id>
        <type>Team</type>
        <initial_short_name>HOME</initial_short_name>
        <initial_name>HOME TEAM</initial_name>
        <initial_primary_color>#7865ab</initial_primary_color>
        <initial_secondary_color>#ffffff</initial_secondary_color>
    </widget>

    <widget>
        <id>away_team</id>
        <type>Team</type>
        <initial_short_name>AWAY</initial_short_name>
        <initial_name>AWAY TEAM</initial_name>
        <initial_primary_color>#7a8888</initial_primary_color>
        <initial_secondary_color>#000000</initial_secondary_color>
    </widget>


    <widget>
        <id>home_score</id>
        <type>Calculation</type>
	<expression>(home_goals * 6) + home_behinds</expression>
    </widget>

    <widget>
        <id>away_score</id>
        <type>Calculation</type>
	<expression>(away_goals * 6) + away_behinds</expression>
    </widget>

</ScoreboardConfig>

