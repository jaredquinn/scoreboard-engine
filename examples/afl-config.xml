<!-- Example Scoreboard Configuration for Rugby League 

     * Home & Away Scores with 4,2,1 shortcuts in dashboard
     * Home & Away Names
     * Match Clock
     * Period
-->
<ScoreboardConfig>
    <persistence_file>afl.json</persistence_file>
    <widget>
        <id>home_goals</id>
        <type>Counter</type>
        <initial_value>0</initial_value>
    </widget>

    <widget>
        <id>home_behinds</id>
        <type>Counter</type>
        <initial_value>0</initial_value>
    </widget>

    <widget>
        <id>away_goals</id>
        <type>Counter</type>
        <initial_value>0</initial_value>
    </widget>

    <widget>
        <id>away_behinds</id>
        <type>Counter</type>
        <initial_value>0</initial_value>
    </widget>

    <widget>
        <id>match_clock</id>
        <type>Timer</type>
        <initial_seconds>0</initial_seconds>
        <is_down>false</is_down>
        <min_value>0</min_value>
        <max_value>2700</max_value>
    </widget>

    <widget>
        <id>period</id>
        <type>MappedList</type>
        <initial_index>0</initial_index>
	<options>
	    <option>PRE GAME</option>
            <option>1ST QTR</option>
	    <option>1/4</option>
            <option>2ND QTR</option>
            <option>HALFTIME</option>
            <option>3RD QTR</option>
	    <option>3/4</option>
            <option>4TH QTR</option>
            <option>FULLTIME</option>
        </options>
    </widget>

    <widget>
        <id>home_team_name</id>
        <type>StaticText</type>
        <content>HOME</content>
    </widget>

    <widget>
        <id>away_team_name</id>
        <type>StaticText</type>
        <content>AWAY</content>
    </widget>

    <widget>
        <id>home_score</id>
        <type>Calculation</type>
	<expression>(home_goals * 6) + home_behinds</expression>
    </widget>

    <widget>
        <id>away_score</id>
        <type>Calculation</type>
	<expression>(away_goals * 6) + away_behinds</expression>
    </widget>

</ScoreboardConfig>

