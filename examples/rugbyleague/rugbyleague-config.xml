<!-- Example Scoreboard Configuration for Rugby League 

     * Home & Away Scores with 4,2,1 shortcuts in dashboard
     * Home & Away Names
     * Match Clock
     * Tackle count
     * Period
-->
<ScoreboardConfig>
    <persistence_file>rugbyleague.json</persistence_file>
    <widget>
        <id>home_score</id>
        <type>Counter</type>
        <initial_value>0</initial_value>
	<increments>
		<value>4</value>
		<value>2</value>
		<value>1</value>
	</increments>
    </widget>

    <widget>
        <id>away_score</id>
        <type>Counter</type>
        <initial_value>0</initial_value>
	<increments>
		<value>4</value>
		<value>2</value>
		<value>1</value>
	</increments>
    </widget>

    <widget>
        <id>match_clock</id>
        <type>Timer</type>
        <initial_seconds>0</initial_seconds>
        <is_down>false</is_down>
        <min_value>0</min_value>
        <max_value>2700</max_value>
    </widget>

    <widget>
        <id>period</id>
        <type>List</type>
        <initial_index>0</initial_index>
	<options>
            <option>1ST HALF</option>
            <option>HALFTIME</option>
            <option>2ND HALF</option>
            <option>FULLTIME</option>
        </options>
    </widget>

    <widget>
        <id>tackle_count</id>
        <type>List</type>
        <initial_index>0</initial_index>
	<options>
            <option>ZERO</option>
	    <option>1ST</option>
            <option>2ND</option>
            <option>3RD</option>
            <option>4TH</option>
            <option>5TH</option>
        </options>
    </widget>

    <widget>
        <id>home_team</id>
        <type>Team</type>
        <initial_short_name>HOME</initial_short_name>
        <initial_name>HOME TEAM</initial_name>
        <initial_primary_color>#7865ab</initial_primary_color>
        <initial_secondary_color>#ffffff</initial_secondary_color>
    </widget>

    <widget>
        <id>away_team</id>
        <type>Team</type>
        <initial_short_name>AWAY</initial_short_name>
        <initial_name>AWAY TEAM</initial_name>
        <initial_primary_color>#7a8888</initial_primary_color>
        <initial_secondary_color>#000000</initial_secondary_color>
    </widget>


</ScoreboardConfig>

